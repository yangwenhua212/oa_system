<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.ChatGroupMapper">

    <select id="selectChatGroupList" resultType="com.oa.system.entity.ChatGroup">
        SELECT * FROM oa_chat_group WHERE del_flag = 0
        ORDER BY create_time DESC
    </select>

</mapper>