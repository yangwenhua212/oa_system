<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.NoticeCommentMapper">

    <select id="selectByNoticeId" resultType="com.oa.system.entity.NoticeComment">
        SELECT * FROM oa_notice_comment
        WHERE notice_id = #{noticeId} AND status = 1
        ORDER BY create_time ASC
    </select>

</mapper>
