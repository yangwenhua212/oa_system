<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.ProcessDefinitionMapper">

    <select id="selectProcessDefinitionList" resultType="com.oa.system.entity.ProcessDefinition">
        SELECT * FROM oa_process_definition WHERE del_flag = 0
        ORDER BY create_time DESC
    </select>

</mapper>