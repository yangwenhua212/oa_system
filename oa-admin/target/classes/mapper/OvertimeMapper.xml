<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.OvertimeMapper">

    <select id="selectOvertimeList" resultType="com.oa.system.entity.Overtime">
        SELECT * FROM oa_overtime WHERE del_flag = 0
        <if test="userId != null">
            AND user_id = #{userId}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>