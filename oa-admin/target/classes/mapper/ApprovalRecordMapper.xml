<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.ApprovalRecordMapper">

    <select id="selectByProcessInstanceId" resultType="com.oa.system.entity.ApprovalRecord">
        SELECT * FROM oa_approval_record
        WHERE process_instance_id = #{processInstanceId}
        ORDER BY id ASC
    </select>

</mapper>
