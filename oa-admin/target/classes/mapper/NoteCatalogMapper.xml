<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.NoteCatalogMapper">

    <select id="selectNoteCatalogList" resultType="com.oa.system.entity.NoteCatalog">
        SELECT * FROM oa_note_catalog WHERE del_flag = 0
        <if test="userId != null">
            AND user_id = #{userId}
        </if>
        ORDER BY sort, id
    </select>

</mapper>